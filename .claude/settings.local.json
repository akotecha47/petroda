{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "PowerShell(Get-ChildItem -Recurse src -File | ForEach-Object { Write-Host \"=== $\\($_.FullName\\) ===\"; Get-Content $_.FullName })",
      "Bash(node *)",
      "Skill(run)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5174/)",
      "Bash(npx playwright *)"
    ]
  }
}
